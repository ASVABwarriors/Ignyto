// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String?
  phone           String?
  password        String?
  twoFactorSecret String?
  isTwoFactorEnabled Boolean @default(false)
  role            Role      @default(USER)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  payments        Payment[]
  gradeWiseCampPayments GradeWiseCampPayment[]
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

model Course {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  description String?
  fee         Float
  duration    String
  dailyHours  String
  category    String
  classMode   String
  imageName   String?
  thumbnailUrl String?
  pdfUrl      String?
  syllabus    String?
  startDate   DateTime?
  timezone    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  payments    Payment[]
  dates       CourseDate[]
  enrollments Enrollment[]
  inquiries   Inquiry[]
}

model Payment {
  id              String   @id @default(cuid())
  userId          String?
  courseId        String
  paypalOrderId   String   @unique
  amount          Float
  status          String   // e.g., "COMPLETED", "PENDING"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User?    @relation(fields: [userId], references: [id])
  course          Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrollment      Enrollment?
}

model CourseDate {
  id        String   @id @default(cuid())
  courseId  String
  dateStr   String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  timeSlots CourseTimeSlot[]
}

model CourseTimeSlot {
  id        String     @id @default(cuid())
  dateId    String
  timeStr   String
  date      CourseDate @relation(fields: [dateId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id              String   @id @default(cuid())
  courseId        String
  paymentId       String?  @unique
  
  studentName     String
  grade           String
  studentEmail    String
  studentPhone    String

  parentName      String?
  parentEmail     String
  parentPhone     String
  
  referredBy      String?
  address         String?
  
  selectedDate    String
  selectedTime    String

  status          String   @default("PENDING") // PENDING, CONFIRMED
  
  course          Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  payment         Payment? @relation(fields: [paymentId], references: [id])
  createdAt       DateTime @default(now())
}

model Inquiry {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String
  message     String
  grade       String?
  courseId    String?
  gradeWiseCampId String?
  city        String?
  state       String?
  trialDate   String?
  trialTime   String?
  status      String   @default("PENDING") // PENDING, RESOLVED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  course      Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  gradeWiseCamp   GradeWiseCamp? @relation(fields: [gradeWiseCampId], references: [id], onDelete: Cascade)
}

model FreeTrialDate {
  id        String   @id @default(cuid())
  dateStr   String   @unique
  timeSlots FreeTrialTimeSlot[]
}

model FreeTrialTimeSlot {
  id        String     @id @default(cuid())
  dateId    String
  timeStr   String
  date      FreeTrialDate @relation(fields: [dateId], references: [id], onDelete: Cascade)
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SectionSetting {
  id          String   @id @default(cuid())
  sectionName String   @unique // e.g., "gradewise-camps"
  title       String?
  description String?
  bannerUrl   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Worksheet {
  id                 String   @id @default(cuid())
  slug               String   @unique
  title              String
  description        String?
  grade              String
  estimatedTime      String   // e.g., "25-30 min"
  questionCount      String   // e.g., "30 Questions"
  pdfUrl             String   // The file to download
  heroImage          String?  // Top right character image
  conceptImage       String?  // Image for 2nd section
  learningObjectives String?  // Rich text for 3rd section
  downloadFeatures   String?  // Newline separated bullet points for download box
  pdfPageCount       String?  // e.g. "2 Pages"
  previewImages      String[] // Array of image URLs for the preview gallery
  isFeatured         Boolean  @default(false) // Whether to show in the featured strip
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  downloads          WorksheetDownload[]
}

model WorksheetDownload {
  id          String   @id @default(cuid())
  worksheetId String
  name        String
  email       String
  grade       String
  createdAt   DateTime @default(now())
  
  worksheet   Worksheet @relation(fields: [worksheetId], references: [id], onDelete: Cascade)
}

model GradeWiseCamp {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  description String?
  fee         Float
  duration    String
  dailyHours  String
  category    String
  classMode   String
  imageName   String?
  thumbnailUrl String?
  pdfUrl      String?
  syllabus    String?
  startDate   DateTime?
  timezone    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  payments    GradeWiseCampPayment[]
  dates       GradeWiseCampDate[]
  enrollments GradeWiseCampEnrollment[]
  inquiries   Inquiry[]
}

model GradeWiseCampPayment {
  id              String   @id @default(cuid())
  userId          String?
  gradeWiseCampId String
  paypalOrderId   String   @unique
  amount          Float
  status          String   // e.g., "COMPLETED", "PENDING"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User?    @relation(fields: [userId], references: [id])
  gradeWiseCamp   GradeWiseCamp @relation(fields: [gradeWiseCampId], references: [id], onDelete: Cascade)
  enrollment      GradeWiseCampEnrollment?
}

model GradeWiseCampDate {
  id              String   @id @default(cuid())
  gradeWiseCampId String
  dateStr         String
  gradeWiseCamp   GradeWiseCamp @relation(fields: [gradeWiseCampId], references: [id], onDelete: Cascade)
  timeSlots       GradeWiseCampTimeSlot[]
}

model GradeWiseCampTimeSlot {
  id        String     @id @default(cuid())
  dateId    String
  timeStr   String
  date      GradeWiseCampDate @relation(fields: [dateId], references: [id], onDelete: Cascade)
}

model GradeWiseCampEnrollment {
  id              String   @id @default(cuid())
  gradeWiseCampId String
  paymentId       String?  @unique
  
  studentName     String
  grade           String
  studentEmail    String
  studentPhone    String

  parentName      String?
  parentEmail     String
  parentPhone     String
  
  referredBy      String?
  address         String?
  
  selectedDate    String
  selectedTime    String

  status          String   @default("PENDING") // PENDING, CONFIRMED
  
  gradeWiseCamp   GradeWiseCamp @relation(fields: [gradeWiseCampId], references: [id], onDelete: Cascade)
  payment         GradeWiseCampPayment? @relation(fields: [paymentId], references: [id])
  createdAt       DateTime @default(now())
}
